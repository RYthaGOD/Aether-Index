{
  "name": "aether-index-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "High-Performance Modular Solana Indexing Engine",
  "workspaces": [
    "packages/aether-core",
    "packages/aether-sdk",
    "packages/aether-agentic",
    "packages/aether-zk",
    "packages/aether-lending",
    "packages/aether-nft",
    "packages/shared"
  ],
  "scripts": {
    "build:shared": "tsc -b packages/shared",
    "build:sdk": "tsc -b packages/aether-sdk",
    "build:shards": "tsc -b packages/aether-agentic packages/aether-zk packages/aether-lending packages/aether-nft",
    "build:core": "tsc -b packages/aether-core",
    "build": "npm run build:shared && npm run build:sdk && npm run build:shards && npm run build:core",
    "backfill": "ts-node -P packages/aether-core/tsconfig.json packages/aether-core/src/bin/backfill.ts",
    "backfill:bags": "ts-node -P packages/aether-core/tsconfig.json packages/aether-core/src/bin/backfill-bags.ts",
    "dev": "npm run dev --workspace=@aether/core",
    "teleport": "powershell -Command \"Remove-Item -Path 'packages/*/dist' -Recurse -Force -ErrorAction SilentlyContinue; npm run build; railway up\"",
    "create-module": "ts-node -P tsconfig.dev.json packages/aether-core/src/bin/aether-cli.ts create-module",
    "simulate": "ts-node -P tsconfig.dev.json packages/aether-core/src/bin/simulate.ts",
    "verify-upgrades": "ts-node -P tsconfig.dev.json packages/aether-core/src/bin/verify-upgrades.ts",
    "start": "npm run start --workspace=@aether/core",
    "test": "npm test --workspaces"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
