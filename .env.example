# ═══════════════════════════════════════
#  Aether Index — Environment Config
# ═══════════════════════════════════════

# Helius API (Required for real-time indexing)
HELIUS_API_KEY=your_key_here
HELIUS_WEBHOOK_URL=https://your-domain.com/helius-webhook
HELIUS_WEBHOOK_SECRET=your_secret_here

# Solana RPC
RPC_URL=https://api.mainnet-beta.solana.com
WSS_URL=wss://api.mainnet-beta.solana.com

# Database Paths (defaults work for Docker)
SQLITE_PATH=./data/sqlite/librarian.db
DUCKDB_PATH=./data/parquet/librarian.duckdb

# Server
PORT=4000
